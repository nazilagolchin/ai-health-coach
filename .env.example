# Copy this file to .env and fill in your values
# Never commit .env to version control

# Anthropic API Key - get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Model to use (claude-haiku-4-5 is cost-effective for portfolio projects)
# Options: claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-8
ANTHROPIC_MODEL=claude-haiku-4-5

# ChromaDB persistence directory (relative path, auto-created)
CHROMA_PERSIST_DIR=data/chroma_db

# Knowledge base documents directory
KNOWLEDGE_DIR=data/knowledge
